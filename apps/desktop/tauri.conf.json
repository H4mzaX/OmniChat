{
  "$schema": "https://raw.githubusercontent.com/nicovrc/tauri-v2-schema/main/src/schema.json",
  "productName": "OmniClaude",
  "version": "1.0.0",
  "identifier": "app.omniclaude.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:4000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../web/build/client"
  },
  "app": {
    "windows": [
      {
        "title": "OmniClaude",
        "width": 1280,
        "height": 860,
        "minWidth": 720,
        "minHeight": 480,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "hiddenTitle": false,
        "url": "/",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.create.xyz https://openrouter.ai; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://fonts.googleapis.com; img-src 'self' data: blob: https:; connect-src 'self' https: http://localhost:*; worker-src 'self' blob:"
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "11.0",
      "exceptionDomain": "",
      "hardenedRuntime": true
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "clipboard-manager": {
      "all": true
    },
    "fs": {
      "scope": {
        "allow": ["$APPDATA/**", "$CACHE/**", "$RESOURCE/**"],
        "deny": []
      }
    }
  }
}
